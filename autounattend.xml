<?xml version="1.0" encoding="utf-8"?>
<unattend xmlns="urn:schemas-microsoft-com:unattend">

    <!-- ================================================================
         windowsPE 阶段 — 安装程序启动环境
         配置来源: tiny11-automated (kelexine)
         新增: DynamicUpdate 静默处理、Compact 压缩安装、Index 指定
         ================================================================ -->
    <settings pass="windowsPE">
        <component
            xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            name="Microsoft-Windows-Setup"
            processorArchitecture="amd64"
            publicKeyToken="31bf3856ad364e35"
            language="neutral"
            versionScope="nonSxS">
            <DynamicUpdate>
                <!-- 安装更新仅在出错时显示界面，否则静默处理 -->
                <WillShowUI>OnError</WillShowUI>
            </DynamicUpdate>
            <ImageInstall>
                <OSImage>
                    <!-- 启用 NTFS 压缩安装，可减少约 30% 磁盘占用 -->
                    <Compact>true</Compact>
                    <WillShowUI>OnError</WillShowUI>
                    <InstallFrom>
                        <MetaData wcm:action="add">
                            <Key>/IMAGE/INDEX</Key>
                            <Value>1</Value>
                        </MetaData>
                    </InstallFrom>
                </OSImage>
            </ImageInstall>
            <UserData>
                <!-- ProductKey 留空 = 自动检测并匹配 ISO 中的版本 -->
                <ProductKey>
                    <Key></Key>
                </ProductKey>
            </UserData>
        </component>
    </settings>

    <!-- ================================================================
         specialize 阶段 — 系统专用化配置
         在安装过程中、OOBE 之前执行
         启用内置 Administrator 账号（无密码、不自动登录）
         ================================================================ -->
    <settings pass="specialize">
        <component
            xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            name="Microsoft-Windows-Deployment"
            processorArchitecture="amd64"
            publicKeyToken="31bf3856ad364e35"
            language="neutral"
            versionScope="nonSxS">
            <RunSynchronous>
                <RunSynchronousCommand wcm:action="add">
                    <Order>1</Order>
                    <Description>启用内置 Administrator 账号（无密码）</Description>
                    <Path>cmd /c net user Administrator /active:yes</Path>
                </RunSynchronousCommand>
            </RunSynchronous>
        </component>
        <!-- 不设置 ComputerName → 自动随机生成 -->
        <!-- 不设置 TimeZone → 保持默认 UTC -->
    </settings>

    <!-- ================================================================
         oobeSystem 阶段 — 首次引导 (OOBE)
         - 不创建任何自定义用户
         - 跳过微软账号登录页（强制本地账号）
         - 不设置 AutoLogon
         ================================================================ -->
    <settings pass="oobeSystem">
        <component
            xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            name="Microsoft-Windows-Shell-Setup"
            processorArchitecture="amd64"
            publicKeyToken="31bf3856ad364e35"
            language="neutral"
            versionScope="nonSxS">
            <OOBE>
                <!-- 跳过微软账号登录页，强制本地账号模式 -->
                <HideOnlineAccountScreens>true</HideOnlineAccountScreens>
                <!-- 跳过 EULA 协议页面 -->
                <HideEULAPage>true</HideEULAPage>
            </OOBE>
            <!-- 不创建 UserAccounts、不设置 AutoLogon、不设 AdministratorPassword -->
            <!-- 首次启动会显示登录页，管理员账号已激活（无密码，点击即登录） -->
        </component>
        <!-- 禁用 Chat/Teams 自动安装（来自 tiny11-automated 原始配置） -->
        <component
            xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            name="Microsoft-Windows-Shell-Setup"
            processorArchitecture="amd64"
            publicKeyToken="31bf3856ad364e35"
            language="neutral"
            versionScope="nonSxS">
            <ConfigureChatAutoInstall>false</ConfigureChatAutoInstall>
        </component>
    </settings>

</unattend>
